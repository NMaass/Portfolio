---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Nicholas Maassen — Full-stack engineer. Shipping software for users' actual workflows." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f5efe0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Theme init — runs before paint to avoid FOUC.
      try {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || stored === 'light') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <a href={`${base}/`} class="site-mark" aria-label="Home">
        <svg width="28" height="28" viewBox="0 0 64 64" aria-hidden="true">
          <rect width="64" height="64" rx="10" fill="currentColor"/>
          <path d="M18 46V20h5l16 18V20h5v26h-5L23 28v18h-5z" fill="var(--color-bg)"/>
        </svg>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href={`${base}/writing`}>Writing</a>
        <a href={`${base}/about`}>About</a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
          <svg class="theme-icon theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" fill="currentColor"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          <svg class="theme-icon theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>
    </header>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <a href="https://github.com/NMaass">GitHub</a>
        ·
        <a href="https://www.linkedin.com/in/nicholas-maassen-63ab53187/">LinkedIn</a>
        ·
        <a href="mailto:nick@nmaass.dev">Email</a>
        ·
        <a href={`${base}/resume.pdf`}>Resume (PDF)</a>
      </p>
    </footer>
    <script>
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;
      function currentTheme() {
        const explicit = html.getAttribute('data-theme');
        if (explicit) return explicit;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      toggle?.addEventListener('click', () => {
        const next = currentTheme() === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
      });
    </script>
  </body>
</html>
