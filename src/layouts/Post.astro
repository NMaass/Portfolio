---
import Base from './Base.astro';
import readingTime from 'reading-time';

interface Frontmatter {
  title: string;
  description?: string;
  date: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { title, description, date } = Astro.props.frontmatter;

const formatted = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const pathname = Astro.url.pathname.replace(/\/$/, '');
const slug = pathname.split('/').pop() || '';

const ogImage = '/og/' + slug + '.png';

// Estimate reading time from the rendered HTML inside the slot.
// Default if we can't read it.
let readText = '5 min read';
try {
  const html = await Astro.slots.render('default');
  const text = String(html).replace(/<[^>]+>/g, ' ');
  if (text.length > 0) {
    const stats = readingTime(text);
    const mins = Math.max(1, Math.round(stats.minutes));
    readText = mins + ' min read';
  }
} catch (e) {
  // keep default
}

const emailSubject = encodeURIComponent('Re: ' + title);
const replyByEmail = 'mailto:nick@nmaass.dev?subject=' + emailSubject;
const linkedinShare =
  'https://www.linkedin.com/sharing/share-offsite/?url=' +
  encodeURIComponent('https://nmaass.dev' + pathname);
---

<Base
  title={`${title} — Nicholas Maassen`}
  description={description}
  ogImage={ogImage}
  ogType="article"
  publishedDate={date}
>
  <article class="post">
    <header class="post-header">
      <h1>{title}</h1>
      <p class="post-meta">
        <time datetime={date}>{formatted}</time>
        <span class="post-meta-sep" aria-hidden="true">·</span>
        <span class="post-read-time">{readText}</span>
      </p>
    </header>
    <div class="post-body">
      <slot />
    </div>
    <footer class="post-footer">
      <p class="post-footer-lede">
        Thanks for reading.
      </p>
      <ul class="post-footer-actions">
        <li>
          <a href={replyByEmail}>Reply by email</a>
        </li>
        <li>
          <a href={linkedinShare} target="_blank" rel="noopener">Share on LinkedIn</a>
        </li>
        <li>
          <a href="/rss.xml">Subscribe via RSS</a>
        </li>
      </ul>
      <p class="post-footer-more">
        More writing on the <a href="/writing">index</a>.
      </p>
    </footer>
  </article>
</Base>

<style>
  .post {
    max-width: var(--max-width-prose);
    margin: 0 auto;
    padding: var(--space-2xl) 0;
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .post-header h1 {
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .post-meta {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .post-meta-sep {
    opacity: 0.6;
  }

  .post-body :global(p) {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-md);
  }

  .post-body :global(h2) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    font-size: var(--text-2xl);
  }

  .post-body :global(h3) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    font-size: var(--text-xl);
  }

  .post-body :global(blockquote) {
    margin: var(--space-xl) 0;
    font-size: var(--text-lg);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-md);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-sm);
  }

  .post-body :global(pre) {
    margin: var(--space-lg) 0;
  }

  .post-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border-soft);
  }

  .post-footer-lede {
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  .post-footer-actions {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg) 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
  }

  .post-footer-actions li {
    margin: 0;
  }

  .post-footer-actions a {
    font-size: var(--text-sm);
  }

  .post-footer-more {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0;
  }
</style>
