---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Nicholas Maassen — Full Stack Engineer">
  <section class="hero">
    <h1>Nicholas Maassen</h1>
    <p class="tagline">
      Full-stack engineer. Shipping software for users' actual workflows.
    </p>
    <p class="lede">
      Contracting with <a href="https://avodahsoftware.com">Avodah Software</a> since Feb 2024.
      Worked on 9 client products across payments, scheduling, AI-assisted healthcare, and
      multi-tenant admin tools, leading 4 end-to-end and contributing substantial slices to 5 more.
      Strong on translating ambiguous client asks into scoped launches, production hardening,
      and prompt engineering for agentic AI.
    </p>
    <p class="hero-now">
      <span class="hero-now-label">Currently</span>
      Mid-level engineer looking for my next role at a devtools or AI company.
      Implementation engineer, forward-deployed engineer, customer engineer, or product engineer.
    </p>
  </section>

  <section class="selected-work">
    <h2>Selected Work</h2>

    <article class="project">
      <a class="project-media project-media-pair" href="https://cube-merge.nmaass.dev" aria-label="Open Cube Merge">
        <img
          class="project-media-desktop"
          src={`${base}/projects/cube-merge.png`}
          alt="Cube Merge diff view on desktop: removals on the left, additions on the right, grouped by color."
          loading="lazy"
          width="1280"
          height="800"
        />
        <img
          class="project-media-mobile"
          src={`${base}/projects/cube-merge-mobile.png`}
          alt="Cube Merge mobile view: same diff, stacked layout."
          loading="lazy"
          width="375"
          height="812"
        />
      </a>
      <header class="project-header">
        <h3><a href="https://cube-merge.nmaass.dev">Cube Merge</a></h3>
        <span class="project-meta">Lighthouse 100/100 · 307 KB</span>
      </header>
      <p class="project-stack">TypeScript · React · Firestore · Cloudflare Pages</p>
      <p>
        Real-time review tool for cube-building hobbyists. Immutable change log lets any anonymous user
        branch and re-share from any prior point, so identity-based trust is unnecessary.
        Six change types (swap / add / remove / keep / reject / decline), threaded @-mention comments,
        virtualized rendering for 500+ cards, CubeCobra-compatible export.
      </p>
      <p class="project-links">
        <a href="https://cube-merge.nmaass.dev">Live</a>
        ·
        <a href="https://github.com/NMaass/cube-merge">Code</a>
      </p>
    </article>

    <article class="project">
      <a class="project-media" href="https://trait-ranker.nmaass.dev" aria-label="Open Trait Ranker — drag-and-drop pairwise ranking demo">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          width="1892"
          height="912"
          aria-label="Trait Ranker desktop drag-and-drop interaction"
        >
          <source src={`${base}/projects/trait-ranker.webm`} type="video/webm" />
          <source src={`${base}/projects/trait-ranker.mp4`} type="video/mp4" />
        </video>
      </a>
      <header class="project-header">
        <h3><a href="https://trait-ranker.nmaass.dev">Trait Ranker</a></h3>
        <span class="project-meta">Lighthouse 99/100 · ~50 users</span>
      </header>
      <p class="project-stack">TypeScript · React · Firebase</p>
      <p>
        Drag-and-drop pairwise ranking on desktop and mobile. Heap-sort surfaces a top-7,
        then merge-sort produces the final order, minimizing the comparisons users have to make.
        Includes a social guessing loop where friends try to predict your top traits before you reveal them.
        Anonymous Firebase sessions with exportable results.
      </p>
      <p class="project-links">
        <a href="https://trait-ranker.nmaass.dev">Live</a>
        ·
        <a href="https://github.com/NMaass/trait-ranker">Code</a>
      </p>
    </article>

    <article class="project">
      <div class="project-media project-media-stat" aria-hidden="true">
        <div class="stat-grid">
          <div class="stat"><span class="stat-num">4</span><span class="stat-label">Led end-to-end</span></div>
          <div class="stat"><span class="stat-num">5</span><span class="stat-label">Slices contributed</span></div>
          <div class="stat"><span class="stat-num">100</span><span class="stat-label">Production Lighthouse</span></div>
        </div>
      </div>
      <header class="project-header">
        <h3>Avodah Software (Feb 2024–present)</h3>
        <span class="project-meta">Contract · NDA-safe summary</span>
      </header>
      <p class="project-stack">TypeScript · React · Bun · Fastify · Cloudflare Workers · Supabase · Stripe Connect · Microsoft Graph · Deepgram</p>
      <p>
        Worked on 9 client products at Avodah since Feb 2024 — led 4 end-to-end and contributed substantial
        slices to 5 more. Highlights: an AI-assisted healthcare workflow with streaming transcription,
        Microsoft Bookings/Teams integration, and parallel-agent LLM review; a GoHighLevel + Cloudflare
        Workers scheduling integration; a B2B used-car wholesale marketplace with Stripe Connect ACH
        escrow, FedEx integration, and an invite/onboarding flow.
      </p>
      <p class="project-links">
        <a href={`${base}/resume.pdf`}>Resume (PDF)</a>
      </p>
    </article>
  </section>

  <section class="side-projects">
    <h2>Side projects</h2>
    <ul class="side-list">
      <li class="side-row">
        <a class="side-title" href="https://pizza-research.nmaass.dev">Pizza Research</a>
        <p class="side-description">
          A discovery app for finding pizza you'll actually like. Cloudflare Worker
          serving a Vite client, Durable Objects for combo tracking, KV for the topping taxonomy.
        </p>
        <p class="side-stack">TypeScript · React · Cloudflare Workers · Durable Objects · KV</p>
      </li>
      <li class="side-row">
        <a class="side-title" href="https://shape-research.nmaass.dev">Shape Research</a>
        <p class="side-description">
          A small playground for thinking about shapes. Cloudflare Worker
          with a Shape Registry Durable Object and a Vite client.
        </p>
        <p class="side-stack">TypeScript · React · Cloudflare Workers · Durable Objects · KV</p>
      </li>
    </ul>
  </section>

  <section class="recent-writing">
    <h2>Writing</h2>
    <ul class="writing-list">
      <li>
        <a href={`${base}/writing/put-the-hammer-down`}>Put the hammer down</a>
        <span class="writing-date">May 2026</span>
      </li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .hero h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
  }

  .tagline {
    font-size: var(--text-xl);
    color: var(--color-accent);
    font-style: italic;
    margin-bottom: var(--space-md);
    line-height: var(--leading-snug);
  }

  .lede {
    max-width: var(--max-width-prose);
    color: var(--color-text);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .hero-now {
    max-width: var(--max-width-prose);
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .hero-now-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: var(--space-sm);
  }

  .selected-work {
    padding: var(--space-2xl) 0;
  }

  .selected-work h2,
  .side-projects h2,
  .recent-writing h2 {
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .side-projects {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border-soft);
  }

  .side-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  @media (max-width: 720px) {
    .side-list { grid-template-columns: 1fr; }
  }

  .side-row {
    padding: 0;
  }

  .side-title {
    display: block;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: var(--space-sm);
  }

  .side-title:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-highlight-text);
  }

  .side-description {
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-sm);
  }

  .side-stack {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .project {
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .project:last-of-type {
    border-bottom: none;
  }

  /* Matt around every screenshot: paper-tone surround so the app's own palette
     never butts directly against the site palette. Same treatment for desktop,
     mobile pair, GIF, or stat block. */
  .project-media {
    display: block;
    width: 100%;
    margin-bottom: var(--space-lg);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
  }

  a.project-media {
    transition: border-color 0.2s ease;
  }

  a.project-media:hover {
    border-color: var(--color-accent);
  }

  .project-media > img,
  .project-media > video {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    /* Sharp 1px line + soft shadow so the screenshot edge is always visible,
       even when the app's own palette is close to the matt color. */
    border: 1px solid var(--color-border);
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  /* Desktop + mobile pair: desktop fills the row, mobile sits at the right edge */
  .project-media-pair {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-md);
    align-items: end;
  }

  .project-media-pair img {
    display: block;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  .project-media-desktop {
    width: 100%;
    height: auto;
  }

  .project-media-mobile {
    width: 160px;
    height: auto;
  }

  @media (max-width: 600px) {
    .project-media-pair {
      grid-template-columns: 1fr;
      justify-items: center;
    }
    .project-media-mobile {
      width: 50%;
    }
  }

  .project-media-stat {
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    /* solid bg (not gradient) so axe can compute contrast for the stat text */
    background: var(--color-bg-elevated);
    padding: var(--space-2xl);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
    text-align: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .stat-num {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .stat-grid { gap: var(--space-md); }
    .stat-num { font-size: var(--text-2xl); }
  }

  .project-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .project-header h3 {
    margin: 0;
    font-size: var(--text-xl);
  }

  .project-header h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-header h3 a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-highlight);
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.02em;
  }

  .project-stack {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .project p {
    max-width: var(--max-width-prose);
    line-height: var(--leading-relaxed);
  }

  .project-links {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  .recent-writing {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border-soft);
  }

  .writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .writing-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
  }

  .writing-list a {
    font-size: var(--text-lg);
  }

  .writing-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
