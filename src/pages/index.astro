---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const liveApps = [
  {
    name: 'Cube Merge',
    url: 'https://cube-merge.nmaass.dev',
    description: 'Real-time review tool for cube-building hobbyists. Branch and re-share from any point.',
    stack: 'React · Firestore · Cloudflare Pages',
  },
  {
    name: 'Trait Ranker',
    url: 'https://trait-ranker.nmaass.dev',
    description: 'Drag-and-drop pairwise ranking with heap-sort and a social guessing loop.',
    stack: 'React · Firebase',
  },
  {
    name: 'Pizza Research',
    url: 'https://pizza-research.nmaass.dev',
    description: 'A discovery app for finding pizza you\'ll actually like. Durable Objects for combo tracking.',
    stack: 'React · Cloudflare Workers · Durable Objects',
  },
  {
    name: 'Shape Research',
    url: 'https://shape-research.nmaass.dev',
    description: 'A small playground for thinking about shapes. Shape Registry Durable Object + Vite client.',
    stack: 'React · Cloudflare Workers · Durable Objects',
  },
  {
    name: 'Bare Recipe',
    url: 'https://recipes.nmaass.dev',
    description: 'Paste a recipe URL, get just the recipe. No ads, no life stories.',
    stack: 'React · Vite · Cloudflare Workers',
  },
];
---

<Base title="Nicholas Maassen — Full Stack Engineer">
  <section class="hero">
    <h1>Nicholas Maassen</h1>
    <p class="tagline">
      Full-stack engineer building workflow-heavy software.
    </p>
    <p class="lede">
      I work across product scoping, UI, backend, vendor APIs, infrastructure, demos, and
      production hardening. Recently: scheduling sync, payment workflows, AI-assisted care
      reports, CRM dashboards, and integration-heavy admin tools.
    </p>
    <p class="hero-now">
      <span class="hero-now-label">Looking for</span>
      Product engineering, implementation engineering, customer engineering, or
      forward-deployed engineering roles at teams that care about useful software, clear
      writing, and shipping to real users.
    </p>
  </section>

  <section class="featured-writing">
    <h2>Latest writing</h2>
    <a class="writing-feature" href={`${base}/writing/flip-the-hammer-over`}>
      <div class="writing-feature-body">
        <h3>Flip the hammer over</h3>
        <p class="writing-feature-desc">How I learned to write as little software as possible.</p>
        <p class="writing-feature-meta">
          <time datetime="2026-05-08">May 8, 2026</time>
        </p>
      </div>
      <span class="writing-feature-cta" aria-hidden="true">Read&nbsp;&rarr;</span>
    </a>
  </section>

  <section class="selected-work">
    <h2>Selected Work</h2>

    <article class="project">
      <a class="project-media" href="https://cube-merge.nmaass.dev" aria-label="Open Cube Merge">
        <img
          src={`${base}/projects/cube-merge.png`}
          alt="Cube Merge diff view on desktop: removals on the left, additions on the right, grouped by color."
          loading="lazy"
          width="1280"
          height="800"
        />
      </a>
      <div class="project-body">
        <header class="project-header">
          <h3><a href="https://cube-merge.nmaass.dev">Cube Merge</a></h3>
          <span class="project-meta">Lighthouse 100/100 · 307 KB</span>
        </header>
        <p class="project-stack">TypeScript · React · Firestore · Cloudflare Pages</p>
        <p>
          Real-time review tool for cube-building hobbyists. Immutable change log lets any anonymous user
          branch and re-share from any prior point, so identity-based trust is unnecessary.
          Six change types (swap / add / remove / keep / reject / decline), threaded @-mention comments,
          virtualized rendering for 500+ cards, CubeCobra-compatible export.
        </p>
        <p class="project-links">
          <a href="https://cube-merge.nmaass.dev">Live</a>
          ·
          <a href="https://github.com/NMaass/cube-merge">Code</a>
        </p>
      </div>
    </article>

    <article class="project">
      <a class="project-media" href="https://trait-ranker.nmaass.dev" aria-label="Open Trait Ranker — drag-and-drop pairwise ranking demo">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          width="1892"
          height="912"
          aria-label="Trait Ranker desktop drag-and-drop interaction"
        >
          <source src={`${base}/projects/trait-ranker.webm`} type="video/webm" />
          <source src={`${base}/projects/trait-ranker.mp4`} type="video/mp4" />
        </video>
      </a>
      <div class="project-body">
        <header class="project-header">
          <h3><a href="https://trait-ranker.nmaass.dev">Trait Ranker</a></h3>
          <span class="project-meta">Lighthouse 99/100 · ~50 users</span>
        </header>
        <p class="project-stack">TypeScript · React · Firebase</p>
        <p>
          Drag-and-drop pairwise ranking on desktop and mobile. Heap-sort surfaces a top-7,
          then merge-sort produces the final order, minimizing the comparisons users have to make.
          Includes a social guessing loop where friends try to predict your top traits before you reveal them.
          Anonymous Firebase sessions with exportable results.
        </p>
        <p class="project-links">
          <a href="https://trait-ranker.nmaass.dev">Live</a>
          ·
          <a href="https://github.com/NMaass/trait-ranker">Code</a>
        </p>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>Cloudflare Workers</li>
          <li>D1</li>
          <li>Hono</li>
          <li>React</li>
          <li>Clerk</li>
          <li>Sentry</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>Scheduling sync for pregnancy centers</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <p class="project-stack">Cloudflare Workers · D1 · Hono · React · Clerk · Sentry</p>
        <p>
          GoHighLevel/LifeLead to CoolFocus integration with reconciliation jobs, lifecycle
          mapping, and encrypted credentials. Built the admin setup flow, demo automation,
          and shipped production deployment.
        </p>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>React</li>
          <li>Supabase</li>
          <li>Stripe Connect</li>
          <li>Postmark</li>
          <li>FedEx</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>B2B automotive marketplace</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <p class="project-stack">React · Supabase · Stripe Connect · Postmark · FedEx</p>
        <p>
          ACH checkout, title-verification payout gates, purchase-order states, invitation
          flows, EIN validation, and RLS-backed permissions across a multi-tenant B2B
          wholesale flow.
        </p>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>React</li>
          <li>Bun</li>
          <li>Microsoft Graph</li>
          <li>Deepgram</li>
          <li>OpenAI</li>
          <li>Promptfoo</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>AI-assisted care workflow</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <p class="project-stack">React · Bun · Microsoft Graph · Deepgram · OpenAI · Promptfoo</p>
        <p>
          Booking-to-report pipeline: transcription, LLM-generated reports, prompt/eval
          tooling, and role-based review surfaces. Production auth and domain hardening for
          a healthcare context.
        </p>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>React</li>
          <li>Bun</li>
          <li>Fastify</li>
          <li>Drizzle</li>
          <li>Postgres</li>
          <li>Redtail CRM</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>Financial-planning dashboard</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <p class="project-stack">React · Bun · Fastify · Drizzle · Postgres · Redtail CRM</p>
        <p>
          Dashboard and data-review workflows with Redtail CRM sync. Sanitized local
          fixtures, staging/live data posture, validation, sync logs, and operational
          review UX for advisors.
        </p>
      </div>
    </article>
  </section>

  <section class="live-apps">
    <h2>Try them live</h2>
    <div class="carousel-wrapper">
      <button class="carousel-nav" data-dir="prev" type="button" aria-label="Scroll left">&lsaquo;</button>
      <div class="carousel" id="app-carousel" role="list" aria-label="Hosted applications">
        {liveApps.map((app) => (
          <a class="carousel-card" href={app.url} role="listitem" target="_blank" rel="noopener">
            <h3>{app.name}</h3>
            <p class="carousel-desc">{app.description}</p>
            <p class="carousel-stack">{app.stack}</p>
            <span class="carousel-url">{app.url.replace('https://', '')}&nbsp;&rarr;</span>
          </a>
        ))}
      </div>
      <button class="carousel-nav" data-dir="next" type="button" aria-label="Scroll right">&rsaquo;</button>
    </div>
  </section>
</Base>

<script>
  const carousel = document.getElementById('app-carousel');
  if (carousel) {
    const wrapper = carousel.closest('.carousel-wrapper');
    const buttons = wrapper?.querySelectorAll('.carousel-nav') ?? [];
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = (btn as HTMLButtonElement).dataset.dir === 'next' ? 1 : -1;
        const amount = carousel.clientWidth * 0.75;
        carousel.scrollBy({ left: amount * dir, behavior: 'smooth' });
      });
    });
  }
</script>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .hero h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-sm);
  }

  .tagline {
    font-size: var(--text-xl);
    color: var(--color-accent);
    font-style: italic;
    margin-bottom: var(--space-md);
    line-height: var(--leading-snug);
  }

  .lede {
    max-width: var(--max-width-prose);
    color: var(--color-text);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .hero-now {
    max-width: var(--max-width-prose);
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .hero-now-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: var(--space-sm);
  }

  /* ─── Featured writing ──────────────────────────────────── */

  .featured-writing {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .featured-writing h2,
  .selected-work h2,
  .live-apps h2 {
    margin-bottom: var(--space-lg);
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .writing-feature {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s ease;
  }

  .writing-feature:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    text-decoration: none;
  }

  .writing-feature-body {
    flex: 1;
    min-width: 0;
  }

  .writing-feature h3 {
    margin: 0 0 var(--space-xs) 0;
    font-size: var(--text-xl);
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .writing-feature:hover h3 {
    color: var(--color-accent);
  }

  .writing-feature-desc {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-xs) 0;
  }

  .writing-feature-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin: 0;
  }

  .writing-feature-cta {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .writing-feature {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }

  /* ─── Selected work (two-column) ────────────────────────── */

  .selected-work {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .project {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-xl);
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-border-soft);
    align-items: start;
  }

  .project:last-of-type {
    border-bottom: none;
  }

  @media (max-width: 720px) {
    .project {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  /* Matt around every screenshot: paper-tone surround so the app's own palette
     never butts directly against the site palette. */
  .project-media {
    display: block;
    width: 100%;
    padding: var(--space-md);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
  }

  a.project-media {
    transition: border-color 0.2s ease;
  }

  a.project-media:hover {
    border-color: var(--color-accent);
  }

  .project-media > img,
  .project-media > video {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  .project-media-stack {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-elevated);
    padding: var(--space-lg);
  }

  .stack-plate {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: center;
    align-content: center;
    width: 100%;
    height: 100%;
  }

  .stack-plate li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
  }

  .project-body {
    min-width: 0;
  }

  .project-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .project-header h3 {
    margin: 0;
    font-size: var(--text-xl);
  }

  .project-header h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-header h3 a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-highlight);
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.02em;
  }

  .project-stack {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .project-body p {
    line-height: var(--leading-relaxed);
  }

  .project-links {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  /* ─── Live apps carousel ────────────────────────────────── */

  .live-apps {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .carousel-wrapper {
    display: flex;
    align-items: stretch;
    gap: var(--space-sm);
  }

  .carousel {
    flex: 1;
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    padding-bottom: var(--space-xs);
  }

  .carousel::-webkit-scrollbar {
    height: 4px;
  }
  .carousel::-webkit-scrollbar-track {
    background: transparent;
  }
  .carousel::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }

  .carousel-card {
    scroll-snap-align: start;
    flex: 0 0 calc((100% - 2 * var(--space-md)) / 3);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s ease;
  }

  .carousel-card:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    text-decoration: none;
  }

  .carousel-card h3 {
    margin: 0;
    font-size: var(--text-lg);
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .carousel-card:hover h3 {
    color: var(--color-accent);
  }

  .carousel-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
    flex: 1;
  }

  .carousel-stack {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .carousel-url {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }

  .carousel-nav {
    flex-shrink: 0;
    align-self: center;
    width: 36px;
    height: 36px;
    min-height: 36px;
    min-width: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
  }

  .carousel-nav:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .carousel-nav {
      display: none;
    }
  }
</style>
