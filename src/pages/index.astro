---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const liveApps = [
  {
    name: 'Cube Merge',
    url: 'https://cube-merge.nmaass.dev',
    description: 'Real-time review tool for cube-building hobbyists. Branch and re-share from any point.',
    stack: 'React · Firestore · Cloudflare Pages',
  },
  {
    name: 'Trait Ranker',
    url: 'https://trait-ranker.nmaass.dev',
    description: 'Drag-and-drop pairwise ranking with heap-sort and a social guessing loop.',
    stack: 'React · Firebase',
  },
  {
    name: 'Pizza Research',
    url: 'https://pizza-research.nmaass.dev',
    description: 'A discovery app for finding pizza you\'ll actually like. Durable Objects for combo tracking.',
    stack: 'React · Cloudflare Workers · Durable Objects',
  },
  {
    name: 'Shape Research',
    url: 'https://shape-research.nmaass.dev',
    description: 'A small playground for thinking about shapes. Shape Registry Durable Object + Vite client.',
    stack: 'React · Cloudflare Workers · Durable Objects',
  },
  {
    name: 'Bare Recipe',
    url: 'https://recipes.nmaass.dev',
    description: 'Paste a recipe URL, get just the recipe. No ads, no life stories.',
    stack: 'React · Vite · Cloudflare Workers',
  },
];
---

<Base title="Nicholas Maassen — Full Stack Engineer">
  <section class="hero">
    <h1>Nicholas Maassen</h1>
    <p class="tagline">
      Full-stack engineer building workflow-heavy software.
    </p>
    <p class="lede">
      I work across product scoping, UI, backend, vendor APIs, infrastructure, and
      production hardening — shipping integration-heavy software for real users.
    </p>
    <p class="hero-roles">
      <span class="hero-now-label">Roles</span>
      Product Engineer · Implementation Engineer · Forward-Deployed Engineer
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="mailto:nick@nmaass.dev">Email me</a>
      <a class="btn btn-secondary" href={`${base}/resume`}>View resume</a>
    </div>
  </section>

  <section class="proof-strip" aria-label="Recent work and stack">
    <p class="proof-line">
      <span class="proof-label">Recent work</span>
      scheduling sync · ACH/payment workflows · AI-assisted care reports · CRM dashboards
    </p>
    <p class="proof-line">
      <span class="proof-label">Stack</span>
      TypeScript · React · Cloudflare Workers/D1 · Postgres · Stripe · Microsoft Graph
    </p>
  </section>

  <section class="selected-work" id="work">
    <h2>Selected Work</h2>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>Cloudflare Workers</li>
          <li>D1</li>
          <li>Hono</li>
          <li>React</li>
          <li>Clerk</li>
          <li>Sentry</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>Scheduling sync for pregnancy centers</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <dl class="project-details">
          <dt>Problem</dt>
          <dd>Pregnancy centers needed appointment data synced between GoHighLevel/LifeLead and CoolFocus with reliable reconciliation.</dd>
          <dt>Shipped</dt>
          <dd>GoHighLevel/LifeLead to CoolFocus integration with reconciliation jobs, lifecycle mapping, encrypted credentials, admin setup flow, demo automation, and Sentry monitoring.</dd>
          <dt>Result</dt>
          <dd>Production deployment shipped and running.</dd>
          <dt>Stack</dt>
          <dd>Cloudflare Workers · D1 · Hono · React · Clerk · Sentry</dd>
        </dl>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>React</li>
          <li>Supabase</li>
          <li>Stripe Connect</li>
          <li>Postmark</li>
          <li>FedEx</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>B2B automotive marketplace</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <dl class="project-details">
          <dt>Problem</dt>
          <dd>B2B wholesale used-car transactions needed payment, title verification, and multi-tenant access control.</dd>
          <dt>Shipped</dt>
          <dd>ACH checkout, webhook-driven payment status, title-verification payout gate, purchase-order states, invitation flows, EIN validation, and RLS-backed permissions.</dd>
          <dt>Result</dt>
          <dd>Multi-tenant B2B wholesale transaction flow delivered.</dd>
          <dt>Stack</dt>
          <dd>React · Supabase · Stripe Connect · Postmark · FedEx</dd>
        </dl>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>React</li>
          <li>Bun</li>
          <li>Microsoft Graph</li>
          <li>Deepgram</li>
          <li>OpenAI</li>
          <li>Promptfoo</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>AI-assisted care workflow</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <dl class="project-details">
          <dt>Problem</dt>
          <dd>Care providers needed to turn booking and recording data into structured reports with role-based review.</dd>
          <dt>Shipped</dt>
          <dd>Booking-to-report pipeline: transcription, LLM-generated reports, prompt/eval tooling, and role-based review surfaces.</dd>
          <dt>Result</dt>
          <dd>Production auth and domain hardening for a healthcare context.</dd>
          <dt>Stack</dt>
          <dd>React · Bun · Microsoft Graph · Deepgram · OpenAI · Promptfoo</dd>
        </dl>
      </div>
    </article>

    <article class="project project-nda">
      <div class="project-media project-media-stack" aria-hidden="true">
        <ul class="stack-plate">
          <li>React</li>
          <li>Bun</li>
          <li>Fastify</li>
          <li>Drizzle</li>
          <li>Postgres</li>
          <li>Redtail CRM</li>
        </ul>
      </div>
      <div class="project-body">
        <header class="project-header">
          <h3>Financial-planning dashboard</h3>
          <span class="project-meta">Client work · NDA-safe</span>
        </header>
        <dl class="project-details">
          <dt>Problem</dt>
          <dd>Financial advisors needed CRM-synced dashboard workflows with data review and validation.</dd>
          <dt>Shipped</dt>
          <dd>Dashboard and data-review workflows with Redtail CRM sync, sanitized local fixtures, staging/live data posture, validation, sync logs, and operational review UX.</dd>
          <dt>Result</dt>
          <dd>Advisor-facing review workflows with full reconciliation sync and validation.</dd>
          <dt>Stack</dt>
          <dd>React · Bun · Fastify · Drizzle · Postgres · Redtail CRM</dd>
        </dl>
      </div>
    </article>

    <article class="project">
      <a class="project-media" href="https://cube-merge.nmaass.dev" aria-label="Open Cube Merge">
        <img
          src={`${base}/projects/cube-merge.png`}
          alt="Cube Merge diff view on desktop: removals on the left, additions on the right, grouped by color."
          loading="lazy"
          width="1280"
          height="800"
        />
      </a>
      <div class="project-body">
        <header class="project-header">
          <h3><a href="https://cube-merge.nmaass.dev">Cube Merge</a></h3>
          <span class="project-meta">Side project</span>
        </header>
        <dl class="project-details">
          <dt>Problem</dt>
          <dd>Cube-building hobbyists needed to review and collaborate on changes without accounts or identity-based trust.</dd>
          <dt>Shipped</dt>
          <dd>Real-time review tool with immutable change log, anonymous branching from any prior point, six change types, threaded @-mention comments, virtualized rendering for 500+ cards, and CubeCobra-compatible export.</dd>
          <dt>Result</dt>
          <dd>Lighthouse 100/100 · 307 KB bundle.</dd>
          <dt>Stack</dt>
          <dd>TypeScript · React · Firestore · Cloudflare Pages</dd>
        </dl>
        <p class="project-links">
          <a href="https://cube-merge.nmaass.dev">Live</a>
          ·
          <a href="https://github.com/NMaass/cube-merge">Code</a>
        </p>
      </div>
    </article>

    <article class="project">
      <a class="project-media" href="https://trait-ranker.nmaass.dev" aria-label="Open Trait Ranker — drag-and-drop pairwise ranking demo">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          poster={`${base}/projects/trait-ranker-poster.jpg`}
          width="1892"
          height="912"
          aria-label="Trait Ranker desktop drag-and-drop interaction"
        >
          <source src={`${base}/projects/trait-ranker.webm`} type="video/webm" />
          <source src={`${base}/projects/trait-ranker.mp4`} type="video/mp4" />
        </video>
      </a>
      <div class="project-body">
        <header class="project-header">
          <h3><a href="https://trait-ranker.nmaass.dev">Trait Ranker</a></h3>
          <span class="project-meta">Side project</span>
        </header>
        <dl class="project-details">
          <dt>Problem</dt>
          <dd>Ranking many traits by comparison is tedious; users need fewer decisions to reach a final order.</dd>
          <dt>Shipped</dt>
          <dd>Drag-and-drop pairwise ranking with heap-sort (top-7) then merge-sort (final order), social guessing loop, anonymous Firebase sessions, and exportable results.</dd>
          <dt>Result</dt>
          <dd>Lighthouse 99/100 · ~50 users.</dd>
          <dt>Stack</dt>
          <dd>TypeScript · React · Firebase</dd>
        </dl>
        <p class="project-links">
          <a href="https://trait-ranker.nmaass.dev">Live</a>
          ·
          <a href="https://github.com/NMaass/trait-ranker">Code</a>
        </p>
      </div>
    </article>
  </section>

  <section class="live-apps" id="demos">
    <h2>Live demos</h2>
    <div class="demo-grid">
      {liveApps.map((app) => (
        <a class="demo-card" href={app.url} target="_blank" rel="noopener">
          <h3>{app.name}</h3>
          <p class="demo-desc">{app.description}</p>
          <p class="demo-stack">{app.stack}</p>
          <span class="demo-url">{app.url.replace('https://', '')}&nbsp;&rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="featured-writing">
    <h2>Latest writing</h2>
    <a class="writing-feature" href={`${base}/writing/flip-the-hammer-over`}>
      <div class="writing-feature-body">
        <h3>Flip the hammer over</h3>
        <p class="writing-feature-desc">How I learned to write as little software as possible.</p>
        <p class="writing-feature-meta">
          <time datetime="2026-05-08">May 8, 2026</time>
        </p>
      </div>
      <span class="writing-feature-cta" aria-hidden="true">Read&nbsp;&rarr;</span>
    </a>
  </section>
</Base>

<script is:inline>
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('video[autoplay]').forEach(function (v) {
      v.removeAttribute('autoplay');
      v.removeAttribute('loop');
      v.pause();
    });
  }
</script>

<style>
  .hero {
    padding: var(--space-md) 0 var(--space-lg);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .hero h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xs);
  }

  .tagline {
    font-size: var(--text-xl);
    color: var(--color-accent);
    font-style: italic;
    margin-bottom: var(--space-sm);
    line-height: var(--leading-snug);
  }

  .lede {
    max-width: var(--max-width-prose);
    color: var(--color-text);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-sm);
  }

  .hero-roles {
    max-width: var(--max-width-prose);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .hero-now-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: var(--space-sm);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-family: var(--font-serif);
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    line-height: 1;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--color-bg);
    text-decoration: none;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ─── Proof strip ───────────────────────────────────────── */

  .proof-strip {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .proof-line {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .proof-line + .proof-line {
    margin-top: var(--space-xs);
  }

  .proof-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: var(--space-sm);
  }

  /* ─── Featured writing ──────────────────────────────────── */

  .featured-writing {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-top: 1px solid var(--color-border-soft);
  }

  .featured-writing h2,
  .selected-work h2,
  .live-apps h2 {
    margin-bottom: var(--space-lg);
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .writing-feature {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s ease;
  }

  .writing-feature:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    text-decoration: none;
  }

  .writing-feature-body {
    flex: 1;
    min-width: 0;
  }

  .writing-feature h3 {
    margin: 0 0 var(--space-xs) 0;
    font-size: var(--text-xl);
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .writing-feature:hover h3 {
    color: var(--color-accent);
  }

  .writing-feature-desc {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-xs) 0;
  }

  .writing-feature-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin: 0;
  }

  .writing-feature-cta {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .writing-feature {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }

  /* ─── Selected work (two-column) ────────────────────────── */

  .selected-work {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .project {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-xl);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border-soft);
    align-items: start;
  }

  .project:last-of-type {
    border-bottom: none;
  }

  @media (max-width: 720px) {
    .project {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  .project-media {
    display: block;
    width: 100%;
    padding: var(--space-md);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
  }

  a.project-media {
    transition: border-color 0.2s ease;
  }

  a.project-media:hover {
    border-color: var(--color-accent);
  }

  .project-media > img,
  .project-media > video {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  .project-media-stack {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-elevated);
    padding: var(--space-lg);
  }

  .stack-plate {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: center;
    align-content: center;
    width: 100%;
    height: 100%;
  }

  .stack-plate li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg);
  }

  .project-body {
    min-width: 0;
  }

  .project-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .project-header h3 {
    margin: 0;
    font-size: var(--text-xl);
  }

  .project-header h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-header h3 a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-highlight);
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.02em;
  }

  .project-details {
    margin: 0;
  }

  .project-details dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-highlight-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .project-details dt:first-child {
    margin-top: 0;
  }

  .project-details dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .project-details dd:last-of-type {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .project-links {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  /* ─── Live demos grid ───────────────────────────────────── */

  .live-apps {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  .demo-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s ease;
  }

  .demo-card:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    text-decoration: none;
  }

  .demo-card h3 {
    margin: 0;
    font-size: var(--text-lg);
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .demo-card:hover h3 {
    color: var(--color-accent);
  }

  .demo-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
    flex: 1;
  }

  .demo-stack {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .demo-url {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }
</style>
