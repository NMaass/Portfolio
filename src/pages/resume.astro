---
  import Base from '../layouts/Base.astro';
  const title = 'Nicholas Maassen — Resume';
  const description = 'One-page technical resume — Nicholas Maassen, full-stack engineer.';
  // TODO: replace with your actual phone number.
  const phone = '(000) 000-0000';
---

<Base {title} {description} noChrome>
  <article class="resume" id="resume">
    <header class="r-head">
      <h1 class="r-name">Nicholas Maassen</h1>
      <p class="r-contact">
        Westland, MI
        <span aria-hidden="true">·</span>
        <a href="mailto:nick@nmaass.dev">nick@nmaass.dev</a>
        <span aria-hidden="true">·</span>
        <span class="r-phone">{phone}</span>
        <span aria-hidden="true">·</span>
        <a href="https://nmaass.dev">nmaass.dev</a>
        <span aria-hidden="true">·</span>
        <a href="https://github.com/NMaass">github.com/NMaass</a>
        <span aria-hidden="true">·</span>
        <a href="https://www.linkedin.com/in/nicholas-maassen-63ab53187/">LinkedIn</a>
      </p>
    </header>

    <section class="r-block">
      <h2 class="r-section-title">Summary</h2>
      <p class="r-summary">
        Full-stack engineer at Avodah Software since Feb 2024, building client-facing software across
        scheduling, payments, AI-assisted workflows, CRM dashboards, and integrations. Strongest where
        product scoping, TypeScript/React implementation, vendor APIs, infrastructure, and production
        hardening meet.
      </p>
    </section>

    <section class="r-block">
      <h2 class="r-section-title">Skills</h2>
      <p class="r-skills">
        TypeScript, React, Node/Bun, Fastify, Hono, PostgreSQL, Supabase, Drizzle, Firebase,
        Cloudflare Workers/D1/Pages, Stripe Connect, Clerk, Sentry, Microsoft Graph, Deepgram,
        OpenAI/OpenRouter, Promptfoo, Playwright, Vitest
      </p>
    </section>

    <section class="r-block">
      <h2 class="r-section-title">Experience</h2>
      <div class="r-role">
        <div class="r-role-head">
          <strong>Avodah Software</strong> — Full Stack Software Engineer
          <span class="r-dates">Feb 2024–Present</span>
        </div>
        <ul class="r-bullets">
          <li>
            Built client-facing software across scheduling, payments, healthcare workflows, CRM
            dashboards, and integration-heavy admin tools; worked across product scoping, UI,
            backend, vendor APIs, deployment, demos, and production hardening.
          </li>
          <li>
            Built a Cloudflare Workers/D1 scheduling integration syncing LifeLead/GoHighLevel
            appointments into CoolFocus for pregnancy centers, including reconciliation jobs,
            encrypted credentials, admin setup, Sentry monitoring, and demo/E2E tooling.
          </li>
          <li>
            Implemented major transaction and onboarding flows for a B2B used-car marketplace:
            Stripe Connect ACH checkout, webhook-driven payment status, title-verification payout
            gate, purchase-order states, FedEx/Postmark support, and RLS-backed permissions.
          </li>
          <li>
            Worked on an AI-assisted care-report workflow integrating Microsoft Bookings/Teams,
            recording ingest, Deepgram transcription, LLM-generated reports, Promptfoo evals, and
            role-specific review/report surfaces.
          </li>
          <li>
            Built Redtail CRM dashboard/data-review workflows for a financial-planning client,
            including full reconciliation sync, validation/error surfacing, sync logs, sanitized
            local fixtures, and staging/live-data handling.
          </li>
          <li>
            Used AI coding tools daily with explicit specs, tests, review passes, and prompt/eval
            workflows; strongest results came from small vertical slices plus careful
            verification rather than large unreviewed agent runs.
          </li>
        </ul>
      </div>
    </section>

    <section class="r-block">
      <h2 class="r-section-title">Projects</h2>
      <ul class="r-projects">
        <li>
          <strong>Cube Merge</strong> — TypeScript, React, Firestore, Cloudflare Pages<br />
          <span class="r-proj-desc">Real-time cube-change review tool with no-account collaboration, immutable change history, branching, threaded comments, and CubeCobra export.</span>
        </li>
        <li>
          <strong>Trait Ranker</strong> — TypeScript, React, Firebase<br />
          <span class="r-proj-desc">Pairwise ranking app using heap-sort and merge-sort to reduce user comparisons, with anonymous sessions and a social guessing loop.</span>
        </li>
      </ul>
    </section>

    <section class="r-block r-tight">
      <h2 class="r-section-title">Earlier Experience</h2>
      <ul class="r-old">
        <li><strong>Politics on the Go</strong> — Full Stack SE Intern · Jan 2023–May 2023</li>
        <li><strong>Grand Circus</strong> — JavaScript Teaching Assistant · Sep 2022–Jan 2023</li>
        <li><strong>Blue Cross Blue Shield of Michigan</strong> — CS Intern · 2019</li>
        <li><strong>Cochrane Supply &amp; Engineering</strong> — Intern · 2016–2019</li>
      </ul>
    </section>

    <section class="r-block r-tight">
      <h2 class="r-section-title">Education</h2>
      <p class="r-edu">
        <strong>Wayne State University</strong> — B.S. Computer Science · May 2023
      </p>
    </section>
  </article>
</Base>

<style>
  /* ------ Screen layout (centered, print-ready look) ------ */
  .resume {
    max-width: 8.5in;
    margin: var(--space-xl) auto;
    padding: 0.55in 0.6in;
    font-family: var(--font-serif);
    font-size: 10.5pt;
    line-height: 1.34;
    color: var(--color-text);
  }

  .r-head {
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .r-name {
    font-size: 22pt;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0 0 0.15rem 0;
    line-height: 1;
  }
  .r-contact {
    font-size: 10pt;
    margin: 0;
    color: var(--color-text-muted);
  }
  .r-contact a {
    color: var(--color-text);
    text-decoration: none;
  }
  .r-contact span[aria-hidden="true"] {
    margin: 0 0.35em;
    color: var(--color-border);
  }
  .r-phone {
    color: var(--color-text-muted);
  }

  .r-block {
    margin-top: 0.6rem;
  }
  .r-block.r-tight {
    margin-top: 0.45rem;
  }

  .r-section-title {
    font-size: 10.5pt;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.12rem;
    margin: 0 0 0.35rem 0;
    font-weight: 600;
  }

  .r-summary,
  .r-skills {
    margin: 0;
    font-size: 10.5pt;
  }
  .r-skills {
    color: var(--color-text-muted);
  }

  .r-role {
    margin: 0;
  }
  .r-role-head {
    font-size: 10.5pt;
    margin-bottom: 0.2rem;
  }
  .r-role-head strong {
    font-weight: 600;
  }
  .r-dates {
    float: right;
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .r-bullets,
  .r-projects,
  .r-old {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .r-bullets {
    padding-left: 0.9rem;
  }
  .r-bullets li {
    position: relative;
    margin-bottom: 0.22rem;
    padding-left: 0;
  }
  .r-bullets li::before {
    content: '•';
    position: absolute;
    left: -0.7rem;
    color: var(--color-text-muted);
  }

  .r-projects li {
    margin-bottom: 0.25rem;
  }
  .r-projects strong {
    font-weight: 600;
  }
  .r-proj-desc {
    color: var(--color-text-muted);
  }

  .r-old {
    font-size: 10pt;
    color: var(--color-text-muted);
  }
  .r-old li {
    margin-bottom: 0.12rem;
  }
  .r-old strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .r-edu {
    margin: 0;
    font-size: 10.5pt;
  }
  .r-edu strong {
    font-weight: 600;
  }

  /* ------ Print: force one page ------ */
  @media print {
    :root {
      --color-text: #111111;
      --color-text-muted: #333333;
      --color-accent: #111111;
      --color-border: #999999;
    }

    html, body {
      background: #ffffff !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* hide all site chrome */
    .site-header,
    .site-footer,
    .skip-link {
      display: none !important;
    }

    main {
      max-width: none !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .resume {
      margin: 0;
      padding: 0.28in 0.5in;
      max-width: none;
      width: 7.5in;
      font-size: 10.5pt;
      line-height: 1.2;
    }

    .r-name {
      font-size: 18pt;
      margin-bottom: 0.08rem;
    }

    .r-head {
      margin-bottom: 0.3rem;
    }

    .r-block {
      margin-top: 0.32rem;
    }
    .r-block.r-tight {
      margin-top: 0.24rem;
    }

    .r-section-title {
      margin-bottom: 0.22rem;
      padding-bottom: 0.06rem;
    }

    .r-role-head {
      margin-bottom: 0.12rem;
    }

    .r-bullets li {
      margin-bottom: 0.1rem;
    }

    .r-projects li {
      margin-bottom: 0.14rem;
    }

    .r-old {
      font-size: 9.5pt;
    }
    .r-old li {
      margin-bottom: 0.06rem;
    }

    .resume a {
      color: var(--color-text) !important;
      text-decoration: none !important;
    }

    /* keep it to one page */
    .resume,
    .resume * {
      orphans: 2;
      widows: 2;
    }

    @page {
      size: letter;
      margin: 0.45in;
    }
  }

  /* On small screens, give it readable padding */
  @media (max-width: 600px) {
    .resume {
      padding: var(--space-lg) var(--space-md);
      font-size: 11pt;
    }
    .r-name {
      font-size: 18pt;
    }
    .r-dates {
      float: none;
      display: block;
    }
  }
</style>