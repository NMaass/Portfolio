---
  import Base from '../layouts/Base.astro';
  import { resume, resumeLinks } from '../data/resume';

  const title = 'Nicholas Maassen — Resume';
  const description = 'One-page technical resume — Nicholas Maassen, full-stack engineer.';
---

<Base {title} {description} noChrome>
  <article class="resume" id="resume">
    <header class="r-head">
      <h1 class="r-name">{resume.name}</h1>
      <p class="r-contact">
        {resume.location}
        <span aria-hidden="true">·</span>
        <a href={resumeLinks.email}>{resume.email}</a>
        <span aria-hidden="true">·</span>
        <span class="r-phone">{resume.phone}</span>
        <span aria-hidden="true">·</span>
        <a href={resumeLinks.website}>{resume.website}</a>
        <span aria-hidden="true">·</span>
        <a href={resumeLinks.github}>{resume.github}</a>
        <span aria-hidden="true">·</span>
        <a href={resumeLinks.linkedin}>{resume.linkedin}</a>
      </p>
    </header>

    <section class="r-block">
      <h2 class="r-section-title">Summary</h2>
      <p class="r-summary">{resume.summary}</p>
    </section>

    <section class="r-block">
      <h2 class="r-section-title">Skills</h2>
      <div class="r-skills">
        {resume.skills.map((group) => (
          <p>
            <strong>{group.label}:</strong> {group.items.join(', ')}
          </p>
        ))}
      </div>
    </section>

    <section class="r-block">
      <h2 class="r-section-title">Experience</h2>
      {resume.experience.map((role) => (
        <div class="r-role">
          <div class="r-role-grid">
            <div>
              <strong>{role.company}</strong>
              <span class="r-location">{role.location}</span>
            </div>
            <div>
              {role.title}
              <span class="r-dates">{role.dates}</span>
            </div>
          </div>
          {role.groups.map((group) => (
            <section class="r-experience-group">
              <h3>{group.heading}</h3>
              <ul class="r-bullets">
                {group.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </section>
          ))}
        </div>
      ))}
    </section>

    <section class="r-block r-tight">
      <h2 class="r-section-title">Earlier Experience</h2>
      <ul class="r-old">
        {resume.earlierExperience.map((role) => (
          <li>
            <span>
              <strong>{role.company}</strong> - {role.title}
            </span>
            <span class="r-dates">{role.dates}</span>
            <span class="r-old-desc">{role.description}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="r-block r-tight">
      <h2 class="r-section-title">Education</h2>
      <p class="r-edu">
        <span>
          <strong>{resume.education.school}</strong><br />
          {resume.education.degree}
        </span>
        <span>
          {resume.education.location}<br />
          {resume.education.date}
        </span>
      </p>
    </section>

    <section class="r-block">
      <h2 class="r-section-title">Projects</h2>
      <ul class="r-projects">
        {resume.projects.map((project) => (
          <li>
            <div class="r-project-head">
              <strong>{project.name}</strong> - {project.stack}
              <a href={project.url}>{project.url}</a>
            </div>
            <span class="r-proj-desc">{project.description}</span>
          </li>
        ))}
      </ul>
    </section>
  </article>
</Base>

<style>
  .resume {
    max-width: 8.5in;
    margin: var(--space-xl) auto;
    padding: 0.52in 0.58in;
    font-family: var(--font-serif);
    font-size: 10.2pt;
    line-height: 1.28;
    color: var(--color-text);
  }

  .r-head {
    text-align: center;
    margin-bottom: 0.45rem;
  }

  .r-name {
    font-size: 22pt;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0 0 0.12rem;
    line-height: 1;
  }

  .r-contact {
    font-size: 9.7pt;
    margin: 0;
    color: var(--color-text-muted);
  }

  .r-contact a {
    color: var(--color-text);
    text-decoration: none;
  }

  .r-contact span[aria-hidden="true"] {
    margin: 0 0.35em;
    color: var(--color-border);
  }

  .r-phone {
    color: var(--color-text-muted);
  }

  .r-block {
    margin-top: 0.48rem;
  }

  .r-block.r-tight {
    margin-top: 0.38rem;
  }

  .r-section-title {
    font-size: 10.2pt;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.1rem;
    margin: 0 0 0.28rem;
    font-weight: 600;
  }

  .r-summary,
  .r-skills p {
    margin: 0;
    font-size: 10.2pt;
  }

  .r-skills p + p {
    margin-top: 0.1rem;
  }

  .r-skills strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .r-role-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.2rem 1rem;
    font-size: 10.2pt;
    margin-bottom: 0.2rem;
  }

  .r-role-grid > div:nth-child(even),
  .r-edu > span:last-child {
    text-align: right;
  }

  .r-role-grid strong {
    font-weight: 600;
  }

  .r-location,
  .r-dates {
    display: block;
    color: var(--color-text-muted);
  }

  .r-experience-group {
    margin-top: 0.25rem;
  }

  .r-experience-group h3 {
    font-size: 10.2pt;
    margin: 0 0 0.08rem;
    font-weight: 600;
  }

  .r-bullets,
  .r-projects,
  .r-old {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .r-bullets {
    padding-left: 0.9rem;
  }

  .r-bullets li {
    position: relative;
    margin-bottom: 0.1rem;
    padding-left: 0;
  }

  .r-bullets li::before {
    content: '•';
    position: absolute;
    left: -0.7rem;
    color: var(--color-text-muted);
  }

  .r-old li {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0 1rem;
    margin-bottom: 0.18rem;
  }

  .r-old strong,
  .r-projects strong,
  .r-edu strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .r-old-desc {
    color: var(--color-text-muted);
    grid-column: 1 / -1;
  }

  .r-edu {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    margin: 0;
    font-size: 10.2pt;
  }

  .r-projects li {
    margin-bottom: 0.22rem;
  }

  .r-project-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
  }

  .r-project-head a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .r-proj-desc {
    color: var(--color-text-muted);
  }

  @media print {
    :root {
      --color-text: #111111;
      --color-text-muted: #333333;
      --color-accent: #111111;
      --color-border: #999999;
    }

    html,
    body {
      background: #ffffff !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .site-header,
    .site-footer,
    .skip-link {
      display: none !important;
    }

    main {
      max-width: none !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .resume {
      margin: 0;
      padding: 0.12in 0.26in;
      max-width: none;
      width: 7.98in;
      font-size: 8.55pt;
      line-height: 1.07;
    }

    .r-name {
      font-size: 16pt;
      margin-bottom: 0.03rem;
    }

    .r-head {
      margin-bottom: 0.14rem;
    }

    .r-block {
      margin-top: 0.14rem;
    }

    .r-block.r-tight {
      margin-top: 0.12rem;
    }

    .r-section-title {
      font-size: 8.7pt;
      margin-bottom: 0.08rem;
      padding-bottom: 0.02rem;
    }

    .r-summary,
    .r-skills p,
    .r-role-grid,
    .r-experience-group h3,
    .r-edu {
      font-size: 8.55pt;
    }

    .r-role-grid {
      margin-bottom: 0.08rem;
    }

    .r-experience-group {
      margin-top: 0.07rem;
    }

    .r-experience-group h3 {
      margin-bottom: 0.02rem;
    }

    .r-bullets li {
      margin-bottom: 0.01rem;
    }

    .r-old li,
    .r-projects li {
      margin-bottom: 0.04rem;
    }

    .resume a {
      color: var(--color-text) !important;
      text-decoration: none !important;
    }

    .resume,
    .resume * {
      orphans: 2;
      widows: 2;
    }

    @page {
      size: letter;
      margin: 0.28in;
    }
  }

  @media (max-width: 600px) {
    .resume {
      padding: var(--space-lg) var(--space-md);
      font-size: 11pt;
    }

    .r-name {
      font-size: 18pt;
    }

    .r-role-grid,
    .r-edu,
    .r-project-head,
    .r-old li {
      grid-template-columns: 1fr;
    }

    .r-role-grid > div:nth-child(even),
    .r-edu > span:last-child {
      text-align: left;
    }
  }
</style>
