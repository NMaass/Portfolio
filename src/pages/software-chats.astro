---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const BOOKING_URL = 'https://calendar.app.google/tSLRNcWWUGzvcrnf7';
---

<Base
  title="Software chats — Nicholas Maassen"
  description="A few open 30-minute slots for talking about products, tools, workflows, UX details, and AI-assisted building."
>
  <section class="chats">
    <h1>Software chats</h1>

    <p>
      I keep a few 30-minute slots open for conversations with people who care
      about software products.
    </p>

    <p>
      Could be a product you're building, a tool you like, a workflow that feels
      harder than it should, an AI-assisted build process, or just a
      software/product question you want to talk through with another builder.
    </p>

    <p>
      No pitch deck, prep, or formal agenda needed.
    </p>

    <a class="chat-cta" href={BOOKING_URL} target="_blank" rel="noopener">
      Book a 30-minute chat
    </a>
  </section>
</Base>

<style>
  .chats {
    max-width: var(--max-width-prose);
    padding: var(--space-2xl) 0;
  }

  .chats h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xl);
    letter-spacing: -0.01em;
  }

  .chats p {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-md);
  }

  .chat-cta {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-family: var(--font-serif);
    text-decoration: none;
    line-height: 1;
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
    margin-top: var(--space-lg);
  }

  .chat-cta:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--color-bg);
    text-decoration: none;
  }
</style>
